# ── Supabase ──────────────────────────────────────────────────
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# ── Notifications ──────────────────────────────────────────────
# Admin WhatsApp number (with country code, no spaces/+)
VITE_ADMIN_WHATSAPP=919876543210
VITE_ADMIN_EMAIL=admin@varagan.in

# ── Email / Formspree / EmailJS ────────────────────────────────
# Use either Formspree (easier, no npm needed) OR EmailJS
VITE_FORMSPREE_FORM_ID=your_formspree_id_here

# EmailJS Configuration (Optional fallback)
VITE_EMAILJS_SERVICE_ID=service_xxxxxxx
VITE_EMAILJS_TEMPLATE_ID=template_xxxxxxx
VITE_EMAILJS_PUBLIC_KEY=your_public_key

# ── App ───────────────────────────────────────────────────────
VITE_APP_URL=https://varagan.in
VITE_APP_NAME=Varagan Real Estate
